PORT=3001
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/chesskachaska

# JWT - same secret as the Next.js frontend so tokens are cross-validated
JWT_SECRET=your_super_secret_jwt_key_here
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REQUEST_TOKEN_SECRET=your_request_token_secret_here

# CORS - comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000

# Room settings
ROOM_CLEANUP_INTERVAL_MS=60000
ROOM_DISCONNECT_GRACE_PERIOD_MS=30000
