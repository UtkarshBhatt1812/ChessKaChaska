{
  "name": "chesskachaska-server",
  "version": "1.0.0",
  "description": "Express + Socket.IO backend for ChessKaChaska multiplayer",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "cookie": "^0.7.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
